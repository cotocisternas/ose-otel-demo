        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "histogram_quantile(0.95, sum by (le) (rate(traces_spanmetrics_latency_bucket{service=\"order-consumer\",span_kind=\"SPAN_KIND_CONSUMER\"}[1m])))", "legendFormat": "p95", "refId": "B"},
