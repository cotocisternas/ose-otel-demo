    },
    {
      "type": "nodeGraph",
      "id": 401,
      "title": "Service graph",
      "description": "Tempo metrics-generator service graph (traces_service_graph_request_total in Prometheus). Edges: user → order-producer (HTTP, virtual_node) and order-producer → order-consumer (messaging_system). Empty TraceQL filter '{}' is used because the metric labels (client/server/connection_type) don't include resource.service.name — adding service-name filters here makes Grafana fail to translate to Prometheus and return 'no data found in response'.",
      "datasource": {"type": "tempo", "uid": "tempo"},
      "gridPos": {"h": 11, "w": 12, "x": 0, "y": 26},
      "options": {},
      "targets": [{
        "datasource": {"type": "tempo", "uid": "tempo"},
        "queryType": "serviceMap",
        "serviceMapQuery": "{}",
        "refId": "A"
      }]
    },
    {
      "type": "table",
      "id": 402,
      "title": "RED matrix per service",
      "description": "Rate / Error% / p95 latency by service, restricted to each service's primary entry-point span (SERVER for order-producer's HTTP ingress, CONSUMER for order-consumer's AMQP delivery). One row, one rate — without that filter the table double- or triple-counted internal spans, deflated the error % (denominator inflated by non-message spans), and mixed HTTP+INTERNAL latencies into a meaningless p95. Computed from Tempo metrics-generator span metrics.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 11, "w": 12, "x": 12, "y": 26},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]},
          "custom": {"align": "auto", "cellOptions": {"type": "auto"}}
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "Error %"}, "properties": [
            {"id": "unit", "value": "percent"},
            {"id": "decimals", "value": 2},
            {"id": "custom.cellOptions", "value": {"type": "color-background", "mode": "gradient"}},
            {"id": "thresholds", "value": {"mode": "absolute", "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 5},
              {"color": "red", "value": 15}
            ]}}
          ]},
          {"matcher": {"id": "byName", "options": "p95 (ms)"}, "properties": [
            {"id": "unit", "value": "ms"},
            {"id": "decimals", "value": 1},
            {"id": "custom.cellOptions", "value": {"type": "color-background", "mode": "gradient"}},
            {"id": "thresholds", "value": {"mode": "absolute", "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 50},
              {"color": "red", "value": 200}
            ]}}
          ]},
          {"matcher": {"id": "byName", "options": "Rate (/s)"}, "properties": [
            {"id": "unit", "value": "ops"},
            {"id": "decimals", "value": 2}
          ]}
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {"reducer": ["sum"], "show": false}
      },
      "transformations": [
        {"id": "joinByField", "options": {"byField": "service", "mode": "outer"}},
        {"id": "organize", "options": {
          "excludeByName": {"Time 1": true, "Time 2": true, "Time 3": true},
          "renameByName": {
            "service": "Service",
            "Value #A": "Rate (/s)",
            "Value #B": "Error %",
            "Value #C": "p95 (ms)"
          }
        }}
      ],
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum by (service) (rate(traces_spanmetrics_calls_total{service!=\"compose\",span_kind=~\"SPAN_KIND_(SERVER|CONSUMER)\"}[5m]))", "format": "table", "instant": true, "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "100 * (sum by (service) (rate(traces_spanmetrics_calls_total{service!=\"compose\",span_kind=~\"SPAN_KIND_(SERVER|CONSUMER)\",status_code=\"STATUS_CODE_ERROR\"}[5m])) or (0 * sum by (service) (rate(traces_spanmetrics_calls_total{service!=\"compose\",span_kind=~\"SPAN_KIND_(SERVER|CONSUMER)\"}[5m])))) / scalar(clamp_min(sum(rate(orders_created_total[5m])), 1e-9))", "format": "table", "instant": true, "refId": "B"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "1000 * histogram_quantile(0.95, sum by (le, service) (rate(traces_spanmetrics_latency_bucket{service!=\"compose\",span_kind=~\"SPAN_KIND_(SERVER|CONSUMER)\"}[5m])))", "format": "table", "instant": true, "refId": "C"}
      ]
    },
    {
      "type": "row",
