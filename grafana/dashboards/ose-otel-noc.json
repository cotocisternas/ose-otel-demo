      "url": "/d/ose-otel-demo"
    }
  ],
  "liveNow": false,
  "panels": [
    {
      "type": "stat",
      "id": 100,
      "title": "Orders / sec",
      "description": "Producer-side throughput: rate of orders_created_total — one increment per accepted POST /orders. This is the BUSINESS rate (orders), measured at the system's ingress. Pairs with the consumer-side MESSAGE rate; the two are 1:1 in this demo (no retries / DLQ), so divergence between them would itself be a signal.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 5, "w": 4, "x": 0, "y": 0},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "green", "value": 0.001}
          ]},
          "unit": "ops",
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "graphMode": "area",
        "colorMode": "value",
        "orientation": "auto",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "expr": "sum(rate(orders_created_total[1m]))",
        "refId": "A"
      }]
    },
    {
      "type": "stat",
      "id": 101,
      "title": "Order error rate (5m)",
      "description": "Percentage of orders that fail during consumer processing. Numerator: consumer CONSUMER-kind error spans from Tempo spanmetrics (100% retained by tail sampling keep-errors policy — accurate absolute count). Denominator: orders_created_total (app-emitted counter, not affected by tail sampling). With the demo's 1-in-10 deterministic consumer failure, expect ~10% at steady state. The previous query used spanmetrics for BOTH numerator and denominator, which was inflated ~4x because tail sampling drops ~80% of OK spans but keeps 100% of errors.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 5, "w": 4, "x": 4, "y": 0},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 12},
            {"color": "red", "value": 20}
          ]},
          "unit": "percent",
          "decimals": 1
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "graphMode": "area",
        "colorMode": "value",
        "orientation": "auto",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "expr": "100 * (sum(rate(traces_spanmetrics_calls_total{service=\"order-consumer\",span_kind=\"SPAN_KIND_CONSUMER\",status_code=\"STATUS_CODE_ERROR\"}[5m])) or vector(0)) / clamp_min(sum(rate(orders_created_total[5m])), 1)",
        "refId": "A"
      }]
    },
    {
      "type": "stat",
      "id": 102,
      "title": "Producer p95 latency (SERVER span)",
      "description": "p95 of producer SERVER-kind span duration via Tempo metrics-generator spanmetrics — the time POST /orders spent inside the app. NOT used: http.server.request.duration histogram emitted by the SDK directly — its default explicit-bucket boundaries (5, 10, 25, …, 10000 in seconds) are too coarse to be useful for sub-second HTTP timing, so quantiles interpolate within the 0–5s bucket and look like ~4.8s regardless of true latency.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 5, "w": 4, "x": 8, "y": 0},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 0.05},
            {"color": "red", "value": 0.2}
          ]},
          "unit": "s",
          "decimals": 3
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "graphMode": "area",
        "colorMode": "value",
        "orientation": "auto",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "expr": "histogram_quantile(0.95, sum by (le) (rate(traces_spanmetrics_latency_bucket{service=\"order-producer\",span_kind=\"SPAN_KIND_SERVER\"}[5m])))",
        "refId": "A"
      }]
    },
    {
      "type": "stat",
      "id": 103,
      "title": "Queue depth (broker)",
      "description": "rabbitmq_queue_messages on orders.created from the broker's per-object Prometheus endpoint — the authoritative live depth. Differs from the consumer-emitted orders_queue_depth_estimate (a client-side heuristic; lies under load — reported 11 during a 14k-message backlog in testing). Use this panel for capacity decisions; use the estimate panel as a teaching contrast.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 5, "w": 4, "x": 12, "y": 0},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 100},
            {"color": "red", "value": 500}
          ]},
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "graphMode": "area",
        "colorMode": "value",
        "orientation": "auto",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "expr": "sum(rabbitmq_queue_messages{queue=\"orders.created\"})",
        "refId": "A"
      }]
    },
    {
      "type": "stat",
      "id": 104,
      "title": "Failed messages / sec",
      "description": "Rate of failed message-spans (status=ERROR) across BOTH producer-publish (PRODUCER-kind) and consumer-process (CONSUMER-kind) — one count per failed AMQP envelope on either side. NOC view: any failure anywhere in the messaging path raises this number. Today only the consumer side fails (deterministic 1-in-10 in ProcessingService.processOrder), so this matches the consumer-row 301 ERROR series — but if publish ever starts failing this stat catches it without changing the panel.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 5, "w": 4, "x": 16, "y": 0},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "red", "value": 0.001}
          ]},
          "unit": "ops",
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "graphMode": "area",
        "colorMode": "value",
        "orientation": "auto",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "expr": "sum(rate(traces_spanmetrics_calls_total{service=~\"order-(producer|consumer)\",span_kind=~\"SPAN_KIND_(PRODUCER|CONSUMER)\",status_code=\"STATUS_CODE_ERROR\"}[1m]))",
        "refId": "A"
      }]
    },
    {
      "type": "stat",
      "id": 105,
      "title": "Active services",
      "description": "Count of distinct order-* service.name values reporting OTel resource info — the demo's two app services (order-producer, order-consumer). Filter is intentional: this stat is a fast-glance heartbeat for the messaging path, not a global service inventory. Drops to 1 if either app crashes; goes red at 0.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 5, "w": 4, "x": 20, "y": 0},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "yellow", "value": 1},
            {"color": "green", "value": 2}
          ]},
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "graphMode": "none",
        "colorMode": "value",
        "orientation": "auto",
        "textMode": "value",
        "justifyMode": "auto"
      },
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "expr": "count(group by (job) (target_info{job=~\"ose-otel-demo/order-.*\"}))",
        "refId": "A"
      }]
    },
    {
      "type": "row",
