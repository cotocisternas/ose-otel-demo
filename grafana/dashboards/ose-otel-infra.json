    {
      "type": "row",
      "id": 100,
      "title": "HTTP / AMQP — request flow",
      "collapsed": true,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 4},
      "panels": [
        {
          "type": "timeseries",
          "id": 5,
          "title": "RED — request rate by status",
          "description": "App-emitted http.server.request.duration histogram, _count companion only — rate of requests by HTTP status code. (The bucket distribution from this same histogram is broken and not used in this dashboard for latency; see panel 19's note.)",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "gridPos": {"h": 8, "w": 6, "x": 0, "y": 5},
          "fieldConfig": {
            "defaults": {"custom": {"drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "stacking": {"mode": "none"}}, "unit": "reqps"},
            "overrides": []
          },
          "options": {"legend": {"displayMode": "list", "placement": "bottom", "showLegend": true, "calcs": []}, "tooltip": {"mode": "multi", "sort": "none"}},
          "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum by (http_response_status_code) (rate(http_server_request_duration_seconds_count[1m]))", "legendFormat": "HTTP {{http_response_status_code}}", "refId": "A"}]
        },
        {
          "type": "timeseries",
          "id": 19,
          "title": "RED — latency p95 (producer SERVER spans)",
          "description": "p95 of producer SERVER-kind span duration via Tempo metrics-generator (traces_spanmetrics_latency_bucket). The app's own http_server_request_duration_seconds histogram has too-coarse default SDK buckets (5, 10, 25, …, 10000 in seconds) so its quantiles are pinned at ~4.8s regardless of true latency — the spanmetrics-derived histogram has sane buckets and reflects reality (single-digit ms p95 at typical demo load).",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "gridPos": {"h": 8, "w": 6, "x": 6, "y": 5},
          "fieldConfig": {
            "defaults": {"custom": {"drawStyle": "line", "lineWidth": 1, "fillOpacity": 10}, "unit": "s"},
            "overrides": []
          },
          "options": {"legend": {"displayMode": "list", "placement": "bottom", "showLegend": true, "calcs": []}, "tooltip": {"mode": "multi", "sort": "none"}},
          "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "histogram_quantile(0.95, sum by (le) (rate(traces_spanmetrics_latency_bucket{service=\"order-producer\",span_kind=\"SPAN_KIND_SERVER\"}[1m])))", "legendFormat": "p95 producer SERVER", "refId": "A"}]
        },
        {
          "type": "timeseries",
          "id": 6,
          "title": "AMQP queue depth (broker view)",
          "description": "rabbitmq_queue_messages from rabbitmq_prometheus /metrics/per-object — what the broker says is in each queue right now. Pairs with panel 7 (client estimate).",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "gridPos": {"h": 8, "w": 6, "x": 12, "y": 5},
          "fieldConfig": {
            "defaults": {"custom": {"drawStyle": "line", "lineWidth": 1, "fillOpacity": 10}, "unit": "short"},
            "overrides": []
          },
          "options": {"legend": {"displayMode": "list", "placement": "bottom", "showLegend": true, "calcs": []}, "tooltip": {"mode": "multi", "sort": "none"}},
          "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum by (queue) (rabbitmq_queue_messages{queue!=\"\"})", "legendFormat": "{{queue}} (broker)", "refId": "A"}]
        },
        {
          "type": "timeseries",
          "id": 7,
          "title": "AMQP queue depth (client estimate)",
          "description": "App-emitted orders_queue_depth_estimate gauge — a client-side heuristic from the consumer. KNOWN to diverge from broker reality under load (e.g. estimate=11 while the broker reported 14k during stress testing). Useful as a teaching contrast against panel 6's broker-authoritative reading; do not use for capacity decisions.",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "gridPos": {"h": 8, "w": 6, "x": 18, "y": 5},
          "fieldConfig": {
            "defaults": {"custom": {"drawStyle": "line", "lineWidth": 1, "fillOpacity": 10}, "unit": "short"},
            "overrides": []
          },
          "options": {"legend": {"displayMode": "list", "placement": "bottom", "showLegend": true, "calcs": []}, "tooltip": {"mode": "multi", "sort": "none"}},
          "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "orders_queue_depth_estimate", "legendFormat": "client estimate", "refId": "A"}]
        }
      ]
