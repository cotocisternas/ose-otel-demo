{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "OSE OTel Demo workshop dashboard. Top row = always-visible projector strip (Tempo traces, service graph, RED metrics, Loki logs filtered by trace_id). Bottom row = collapsed deeper-dive (per-priority orders, error spans, raw logs).",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "h": 10,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "title": "Recent Traces (order-producer)",
      "type": "table",
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "query": "{resource.service.name=\"order-producer\"}",
          "queryType": "traceql",
          "limit": 20,
          "tableType": "traces",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "h": 10,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "id": 2,
      "title": "Service Graph",
      "type": "nodeGraph",
      "targets": [
        {
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "serviceMap",
          "refId": "A",
          "serviceMapQuery": "{}"
        }
      ],
      "options": {}
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 10,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "id": 3,
      "title": "RED Metrics",
      "description": "Rate / Errors / Duration on a single time axis. Order rate from the app counter; HTTP duration quantiles from Tempo metrics-generator spanmetrics on producer SERVER spans (NOT the app's http.server.request.duration histogram — its default buckets are too coarse to be useful); queue depth from RabbitMQ broker (authoritative).",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 0,
            "showPoints": "auto"
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(orders_created_total[1m]))",
          "legendFormat": "orders rate (1m)",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(traces_spanmetrics_latency_bucket{service=\"order-producer\",span_kind=\"SPAN_KIND_SERVER\"}[1m])))",
          "legendFormat": "p50 http duration",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(traces_spanmetrics_latency_bucket{service=\"order-producer\",span_kind=\"SPAN_KIND_SERVER\"}[1m])))",
          "legendFormat": "p95 http duration",
          "refId": "C"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(traces_spanmetrics_latency_bucket{service=\"order-producer\",span_kind=\"SPAN_KIND_SERVER\"}[1m])))",
          "legendFormat": "p99 http duration",
          "refId": "D"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rabbitmq_queue_messages{queue=\"orders.created\"})",
          "legendFormat": "queue depth (broker)",
          "refId": "E"
        }
      ]
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 10,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "id": 4,
      "title": "Logs (filtered by latest trace_id)",
      "type": "logs",
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": false,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "{service_name=~\"order-.*\"} | trace_id=~`$traceid`",
          "queryType": "range",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": true,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 10
      },
      "id": 5,
      "title": "Deeper-dive (post-workshop)",
      "type": "row",
      "panels": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "gridPos": {
            "h": 9,
            "w": 8,
            "x": 0,
            "y": 11
          },
          "id": 6,
          "title": "Orders Created by Priority",
          "type": "timeseries",
          "fieldConfig": {
            "defaults": {
              "custom": {
                "drawStyle": "line",
                "lineInterpolation": "linear",
                "lineWidth": 1,
                "fillOpacity": 10,
                "showPoints": "auto"
              },
              "color": {
                "mode": "palette-classic"
              }
            },
            "overrides": []
          },
          "options": {
            "legend": {
              "displayMode": "list",
              "placement": "bottom",
              "showLegend": true
            },
            "tooltip": {
              "mode": "single"
            }
          },
          "targets": [
            {
              "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
              },
              "expr": "sum by (order_priority) (rate(orders_created_total[1m]))",
              "legendFormat": "{{order_priority}}",
              "refId": "A"
            }
          ]
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "gridPos": {
            "h": 9,
            "w": 8,
            "x": 8,
            "y": 11
          },
          "id": 7,
          "title": "Error Spans (Tempo metrics-generator)",
          "type": "timeseries",
          "fieldConfig": {
            "defaults": {
              "custom": {
                "drawStyle": "line",
                "lineInterpolation": "linear",
                "lineWidth": 1,
                "fillOpacity": 10,
                "showPoints": "auto"
              },
              "color": {
                "mode": "palette-classic"
              }
            },
            "overrides": []
          },
          "options": {
            "legend": {
              "displayMode": "list",
              "placement": "bottom",
              "showLegend": true
            },
            "tooltip": {
              "mode": "single"
            }
          },
          "targets": [
            {
              "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
              },
              "expr": "sum(rate(traces_spanmetrics_calls_total{status_code=\"STATUS_CODE_ERROR\"}[1m]))",
              "legendFormat": "error span rate",
              "refId": "A"
            }
          ]
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "gridPos": {
            "h": 9,
            "w": 8,
            "x": 16,
            "y": 11
          },
          "id": 8,
          "title": "Raw Logs (post-workshop poking)",
          "type": "logs",
          "options": {
            "showTime": true,
            "showLabels": false,
            "showCommonLabels": false,
            "wrapLogMessage": false,
            "prettifyLogMessage": false,
            "enableLogDetails": true,
            "dedupStrategy": "none",
            "sortOrder": "Descending"
          },
          "targets": [
            {
              "datasource": {
                "type": "loki",
                "uid": "loki"
              },
              "editorMode": "code",
              "expr": "{service_name=~\"order-.*\"}",
              "queryType": "range",
              "refId": "A"
            }
          ]
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": [
    "ose-otel-demo",
    "workshop",
    "otel"
  ],
  "templating": {
    "list": [
      {
        "name": "traceid",
        "label": "Trace ID filter",
        "type": "textbox",
        "query": "^$",
        "current": {
          "text": "",
          "value": "^$",
          "selected": false
        },
        "skipUrlSync": false,
        "description": "Regex applied to the Loki trace_id structured-metadata filter on the top-row Logs panel. Default '^$' matches no spanned log line — the panel renders empty until you paste a 32-hex trace_id from the Recent Traces panel and press Enter, focusing the log feed on that one request. Default was previously '.+' which streamed every spanned line to the browser; under workshop load (~22k lines/min) that made the panel the slowest on the dashboard."
      }
    ]
  },
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "OSE OTel Demo — Three Signals",
  "uid": "ose-otel-demo",
  "weekStart": ""
}
