{
  "mcpServers": {
    "grafana": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-i",
        "--network=host",
        "-e", "GRAFANA_URL=http://localhost:3000",
        "--entrypoint", "/app/mcp-grafana",
        "mcp/grafana:latest",
        "--transport", "stdio"
      ]
    }
  }
}
